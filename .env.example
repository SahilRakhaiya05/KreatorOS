# Supabase browser/server SSR client config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy fallback for older Supabase projects
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL used by auth redirects in deployed environments
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI provider keys (server-only — never prefix with NEXT_PUBLIC_)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
E2B_API_KEY=

# Never expose service-role or secret keys with NEXT_PUBLIC_.

# Product analytics
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# Stripe Connect and Checkout (server-only)
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
# 0% Commision
STRIPE_PLATFORM_FEE_BPS=0

# Google OAuth Integration Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# High-performance Caching & Rate-Limiting (server-only)
# Standard Redis client (e.g. redis://localhost:6379)
REDIS_URL=
# OR Serverless Edge-compatible Upstash Redis:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Transactional Email via Resend (server-only)
RESEND_API_KEY=
TRANSACTIONAL_FROM_EMAIL="KreatorOS <onboarding@resend.dev>"

# High-priority WhatsApp alerts via Twilio (server-only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
