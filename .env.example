# Supabase browser/server SSR client config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional legacy fallback for older Supabase projects
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL used by auth redirects in deployed environments
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI provider keys (server-only — never prefix with NEXT_PUBLIC_)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Never expose service-role or secret keys with NEXT_PUBLIC_.

POSTHOG_PROJECT_API_KEY=
